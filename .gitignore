# Ignore virtual environment
env/
venv/
.env

# Ignore Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore database
db.sqlite3

# Ignore media files (optional, but usually recommended to not track local uploads)
pic/
media/

# Ignore staticfiles (generated by collectstatic)
staticfiles/

# Ignore logs
*.log

# Ignore OS junk files
.DS_Store
Thumbs.db
